    "## 3. All Compression Methods\n",
    "### 3a. Baselines"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def method_raw(msgs):            return msgs\n",
    "def method_truncate(msgs, k=8): return msgs[-k:]\n",
    "def method_uniform(msgs, r=0.5):\n",
    "    return [{'role':m['role'],'content':extract_top(m['content'],r,m['role'])} for m in msgs]\n",
    "def method_deflate_only(msgs):   return msgs  # deflate applied at eval time\n",
    "\n",
    "print('Baselines ready')"
   ]
